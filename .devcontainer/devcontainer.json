{
  "name": "ha-litellm-conversation Dev",
  "image": "ghcr.io/ludeeus/devcontainer/integration:stable",
  "postCreateCommand": "pip install -e '.[dev]'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.mypy-type-stubs"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "ruff.lint.args": ["--config=ruff.toml"]
      }
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder}/custom_components,target=/workspaces/ha-litellm-conversation/custom_components,type=bind"
  ],
  "remoteUser": "vscode"
}
